{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Legal Contract Intermediate Representation",
    "description": "Formal logical representation of contracts using CNF/DNF clauses with deontic modalities",
    "type": "object",
    "required": [
        "metadata",
        "roles",
        "objects",
        "behaviors",
        "normative_clauses"
    ],
    "properties": {
        "metadata": {
            "$ref": "#/$defs/Metadata"
        },
        "roles": {
            "$ref": "#/$defs/Roles"
        },
        "objects": {
            "$ref": "#/$defs/Objects"
        },
        "behaviors": {
            "$ref": "#/$defs/Behaviors"
        },
        "normative_clauses": {
            "$ref": "#/$defs/NormativeClauses"
        },
        "templates": {
            "$ref": "#/$defs/Templates"
        },
        "principles": {
            "$ref": "#/$defs/Principles"
        }
    },
    "$defs": {
        "Metadata": {
            "type": "object",
            "required": [
                "contract_type",
                "file_name"
            ],
            "properties": {
                "contract_type": {
                    "type": "string"
                },
                "file_name": {
                    "type": "string"
                },
                "classification": {
                    "type": "object",
                    "properties": {
                        "obligations": {
                            "type": "string"
                        },
                        "economic": {
                            "type": "string"
                        },
                        "perfection": {
                            "type": "string"
                        },
                        "execution": {
                            "type": "string"
                        },
                        "dependence": {
                            "type": "string"
                        },
                        "certainty": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "Roles": {
            "type": "object",
            "description": "Map of role identifiers to their types",
            "additionalProperties": {
                "type": "string",
                "enum": [
                    "Person",
                    "Property",
                    "Service",
                    "Money",
                    "Date",
                    "Duration"
                ]
            }
        },
        "Objects": {
            "type": "object",
            "description": "Typed domain entities referenced in the contract",
            "additionalProperties": {
                "type": "object",
                "required": [
                    "type"
                ],
                "properties": {
                    "type": {
                        "type": "string",
                        "enum": [
                            "Money",
                            "Property",
                            "Service",
                            "Date",
                            "Duration",
                            "Document"
                        ]
                    },
                    "attributes": {
                        "type": "object"
                    }
                }
            }
        },
        "Behaviors": {
            "type": "object",
            "description": "Predicate atom templates for behaviors",
            "additionalProperties": {
                "type": "object",
                "required": [
                    "category",
                    "signature"
                ],
                "properties": {
                    "category": {
                        "type": "string",
                        "enum": [
                            "fact",
                            "transfer",
                            "use",
                            "prohibition",
                            "declaration",
                            "termination",
                            "compensation",
                            "maintenance"
                        ]
                    },
                    "signature": {
                        "type": "array",
                        "description": "Ordered list of role/object identifiers",
                        "items": {
                            "type": "string"
                        }
                    },
                    "description": {
                        "type": "string"
                    }
                }
            }
        },
        "NormativeClauses": {
            "type": "array",
            "description": "Canonical CNF/DNF clause representation",
            "items": {
                "type": "object",
                "required": [
                    "id",
                    "form",
                    "literals"
                ],
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "form": {
                        "type": "string",
                        "enum": [
                            "CNF",
                            "DNF"
                        ]
                    },
                    "literals": {
                        "type": "array",
                        "items": {
                            "$ref": "#/$defs/Literal"
                        },
                        "minItems": 1
                    },
                    "clause_arity": {
                        "type": "integer",
                        "description": "Number of literals in the clause"
                    },
                    "source_clause": {
                        "type": "string",
                        "description": "Original text reference"
                    }
                }
            }
        },
        "Literal": {
            "type": "object",
            "required": [
                "kind"
            ],
            "properties": {
                "kind": {
                    "type": "string",
                    "enum": [
                        "behavior",
                        "neg_behavior",
                        "deontic"
                    ]
                },
                "ref": {
                    "type": "string",
                    "description": "Reference to behavior ID"
                },
                "deontic_type": {
                    "type": "string",
                    "enum": [
                        "oblig",
                        "forbid",
                        "claim",
                        "power"
                    ],
                    "description": "Deontic modality (only for deontic literals)"
                }
            }
        },
        "Templates": {
            "type": "array",
            "description": "Template expansion hints",
            "items": {
                "type": "object",
                "required": [
                    "name"
                ],
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "attach_to_clause": {
                        "type": "string"
                    }
                }
            }
        },
        "Principles": {
            "type": "array",
            "description": "Meta-constraints and legal principles",
            "items": {
                "type": "object",
                "required": [
                    "name"
                ],
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "scope": {
                        "type": "string",
                        "enum": [
                            "global",
                            "institution",
                            "clause"
                        ]
                    }
                }
            }
        }
    }
}